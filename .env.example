# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# Ключ Anthropic (мозги ассистента) — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Модель Claude (необязательно; по умолчанию claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Твой Telegram ID — бот будет отвечать только тебе.
# Если не знаешь свой ID: оставь пустым, задеплой, напиши боту — он подскажет ID.
ALLOWED_USER_ID=

# Режим: "polling" локально, "webhook" на Render.
MODE=

# Эти переменные Render задаёт сам. Локально оставь пустыми.
RENDER_EXTERNAL_URL=
PORT=8080
WEBHOOK_SECRET=change-me-to-random-string
