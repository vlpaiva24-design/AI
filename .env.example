# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# Режим работы: "polling" для локальной разработки, "webhook" для Render.
# Если не задан — выбирается автоматически (webhook при наличии RENDER_EXTERNAL_URL).
MODE=

# Эти переменные Render задаёт сам. Локально оставь пустыми.
# Публичный URL сервиса на Render (например https://my-bot.onrender.com)
RENDER_EXTERNAL_URL=
# Порт, который слушает веб-сервер (Render передаёт его автоматически)
PORT=8080

# Секрет для проверки запросов от Telegram к webhook (любая случайная строка)
WEBHOOK_SECRET=change-me-to-random-string
